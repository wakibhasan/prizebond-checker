# Copy this file to `.env` and fill in your local values.
# `.env` itself is gitignored — never commit real credentials.

# Where the Laravel user-API is reachable from the device running the app.
#   Android emulator → host loopback is 10.0.2.2
#   iOS simulator / desktop → 127.0.0.1
#   Physical phone → your LAN IP, e.g. http://192.168.1.5:8000
API_BASE_URL=http://10.0.2.2:8000

# Set to "true" to expose the "Continue without Google" dev-login button on
# the sign-in screen. Leave "false" for any build you don't want shipping
# the auth bypass.
ENABLE_DEV_LOGIN=true

# Web OAuth client ID from Google Cloud Console → APIs & Services → Credentials.
# Used as `serverClientId` so the ID token's `aud` claim matches what the
# backend's GoogleIdTokenVerifier expects. Leave blank to keep the Google
# button disabled (dev-login still works while ENABLE_DEV_LOGIN=true).
GOOGLE_CLIENT_ID=
